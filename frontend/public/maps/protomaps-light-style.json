{
  "version": 8,
  "name": "Protomaps Light",
  "sources": {
    "protomaps": {
      "type": "vector",
      "url": "pmtiles:///maps/landshut-region-test.pmtiles",
      "attribution": "<a href=\"https://github.com/protomaps/basemaps\" target=\"_blank\">Protomaps</a> © <a href=\"https://openstreetmap.org\" target=\"_blank\">OpenStreetMap</a>"
    }
  },
  "sprite": "/maps/protomaps-sprites/sprite",
  "glyphs": "/maps/protomaps-fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f5f5f5"
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#e8e5d5"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "paint": {
        "fill-color": "#c6e4ff"
      }
    },
    {
      "id": "roads-casing",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#d9d9d9",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          0.5,
          15,
          2,
          17,
          4
        ]
      }
    },
    {
      "id": "roads-fill",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": [
        "match",
        [
          "get",
          "kind"
        ],
        [
          "highway",
          "major_road",
          "medium_road",
          "minor_road"
        ],
        true,
        false
      ],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          0.5,
          15,
          1.5,
          17,
          3
        ]
      }
    },
    {
      "id": "roads-walking",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "minzoom": 12,
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#8B6F47",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          12,
          1.0,
          15,
          1.8,
          17,
          2.6
        ],
        "line-dasharray": [
          2,
          1.5
        ],
        "line-opacity": 0.85
      },
      "filter": [
        "match",
        [
          "get",
          "kind"
        ],
        [
          "path"
        ],
        true,
        false
      ]
    },
    {
      "id": "roads-labels",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "roads",
      "minzoom": 14,
      "filter": [
        "match",
        [
          "get",
          "kind"
        ],
        [
          "highway",
          "major_road",
          "medium_road",
          "minor_road"
        ],
        true,
        false
      ],
      "layout": {
        "symbol-placement": "line",
        "text-field": [
          "coalesce",
          [
            "get",
            "name:de"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 11,
        "symbol-spacing": 300
      },
      "paint": {
        "text-color": "#4a4a4a",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "labels",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "layout": {
        "text-field": [
          "get",
          "name"
        ],
        "text-size": 12,
        "text-font": [
          "Noto Sans Regular"
        ]
      },
      "paint": {
        "text-color": "#000000",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.2
      }
    }
  ]
}