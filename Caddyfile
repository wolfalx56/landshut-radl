{
  local_certs
  auto_https disable_redirects
}

m1server.fritz.box, m1server.local, 192.168.178.50 {
  tls internal

  route /radai* {
    root * /
    file_server
  }

  route /caddy-root.crt {
    header Content-Type application/x-x509-ca-cert
    header Content-Disposition "attachment; filename=caddy-root.crt"
    root * /data/caddy/pki/authorities/local
    rewrite * /root.crt
    file_server
  }

  route /siri* {
    uri strip_prefix /siri
    reverse_proxy 192.168.178.50:8766
  }

  route /akito* {
    uri strip_prefix /akito
    reverse_proxy 192.168.178.50:8081
  }

  route /outdoor* {
    uri strip_prefix /outdoor
    reverse_proxy 192.168.178.50:8082
  }

  route /frigate* {
    uri strip_prefix /frigate
    reverse_proxy 192.168.178.50:8083
  }

  route /homebase* {
    uri strip_prefix /homebase
    reverse_proxy 192.168.178.50:8084
  }

  route /travel* {
    uri strip_prefix /travel
    reverse_proxy travel:8095
  }

  route /gallery* {
    uri strip_prefix /gallery
    reverse_proxy 192.168.178.50:8092
  }

  handle_path /maps* {
    root * /maps
    # ETag/Last-Modified weg: Safari macht sonst Conditional Range-Requests,
    # Caddy antwortet dann 304 mit leerem Body -> MapLibre bekommt keine Kacheln
    # und die Karte bleibt weiss (Layer und Features sind da, nur kein Bild).
    header {
      -ETag
      -Last-Modified
      Cache-Control "no-store"
    }
    file_server
  }

  reverse_proxy app:8080
}

:80 {
  route /radai* {
    root * /
    file_server
  }
  route /caddy-root.crt {
    header Content-Type application/x-x509-ca-cert
    header Content-Disposition "attachment; filename=caddy-root.crt"
    root * /data/caddy/pki/authorities/local
    rewrite * /root.crt
    file_server
  }
  route /akito* {
    uri strip_prefix /akito
    reverse_proxy 192.168.178.50:8081
  }
  route /outdoor* {
    uri strip_prefix /outdoor
    reverse_proxy 192.168.178.50:8082
  }
  route /frigate* {
    uri strip_prefix /frigate
    reverse_proxy 192.168.178.50:8083
  }
  route /siri* {
    uri strip_prefix /siri
    reverse_proxy 192.168.178.50:8766
  }
  route /homebase* {
    uri strip_prefix /homebase
    reverse_proxy 192.168.178.50:8084
  }
  route /travel* {
    uri strip_prefix /travel
    reverse_proxy travel:8095
  }
  route /gallery* {
    uri strip_prefix /gallery
    reverse_proxy 192.168.178.50:8092
  }
  handle_path /maps* {
    root * /maps
    file_server
  }
  route {
    reverse_proxy app:8080
  }
}
